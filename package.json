{
  "name": "CAPM-TYPESCRIPT-DEMO",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4.13.0"
  },
  "devDependencies": {
    "@cap-js/cds-typer": ">=0.1",
    "@cap-js/cds-types": "^0.16.0",
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "@types/node": "^24.0.0",
    "cds-plugin-ui5": "^0.17.0",
    "mbt": "^1.2.49",
    "rimraf": "^5.0.5",
    "tsx": "^4",
    "typescript": "^6.0.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-typefiori": "cds watch --open com.subbu.typefiori/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy CAPM-TYPESCRIPT-DEMO --delete-services --delete-service-keys --delete-service-brokers",
    "typecheck": "tsc --noEmit -p tsconfig.cdsbuild.json",
    "build:service": "tsc -p tsconfig.cdsbuild.json",
    "build": "npm run typecheck && npx cds build --production && npm run build:service",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "private": true,
  "cds": {
    "requires": {
      "[production]": {
        "auth": "xsuaa"
      },
      "destinations": true
    }
  },
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/typefiori"
  ]
}
